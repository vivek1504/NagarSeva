
generator client {
  provider = "prisma-client"
  output = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  SURVEYOR
  ENGINEER
}

enum IssueType {
  POTHOLE
  GARBAGE
}

enum IssueStatus {
  DETECTED      
  ASSIGNED     
  IN_PROGRESS   
  FIXED         
  RESOLVED      
  REJECTED      
}

enum RouteAssignmentStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole

  department IssueType?

  wardId   String?
  ward     Ward?    @relation(fields: [wardId], references: [id])

  createdAt DateTime @default(now())

  routeAssignments RouteAssignment[]  
  issueAssignments IssueAssignment[]   
  issueResolutions IssueResolution[]   
  reportedIssues Issue[]               
}

model Ward {
  id     String @id @default(uuid())
  name   String
  number Int    @unique

  userId String?
  user User[]

  routes Route[]
  issues Issue[]
}


model Route {
  id        String @id @default(uuid())
  name      String

  wardId    String
  ward      Ward   @relation(fields: [wardId], references: [id])

  startLat  Float
  startLon  Float
  endLat    Float
  endLon    Float
  distance  Float

  assignments RouteAssignment[]
  issues      Issue[]
}

model RouteAssignment {
  id         String @id @default(uuid())
  routeId    String
  surveyorId String

  status     RouteAssignmentStatus @default(PENDING)

  route      Route @relation(fields: [routeId], references: [id])
  surveyor   User  @relation(fields: [surveyorId], references: [id])

  assignedAt DateTime @default(now())
  completedAt DateTime?

  sessions   SurveySession[]
}

model SurveySession {
  id                String   @id @default(uuid())
  routeAssignmentId String

  startedAt DateTime
  endedAt   DateTime?

  routeAssignment RouteAssignment @relation(fields: [routeAssignmentId], references: [id])
  issues          Issue[]
}

model Issue {
  id              String @id @default(uuid())
  clientCaptureId String @unique  

  type            IssueType?
  status          IssueStatus @default(DETECTED)

  latitude        Float
  longitude       Float

  wardId          String
  ward            Ward @relation(fields: [wardId], references: [id])

  routeId         String
  route           Route @relation(fields: [routeId], references: [id])

  surveySessionId String
  surveySession   SurveySession @relation(fields: [surveySessionId], references: [id])

  surveyorId      String
  surveyor        User @relation(fields: [surveyorId], references: [id])

  imageUrl        String
  afterImageUrl   String?

  assignment      IssueAssignment?
  resolution      IssueResolution?

  createdAt       DateTime @default(now())
}

model IssueAssignment {
  id         String @id @default(uuid())
  issueId    String @unique
  engineerId String

  issue      Issue @relation(fields: [issueId], references: [id])
  engineer   User  @relation(fields: [engineerId], references: [id])

  assignedAt DateTime @default(now())
}


model IssueResolution {
  id                String   @id @default(uuid())
  issueId           String   @unique

  approved          Boolean  @default(false)
  feedback          String?

  verifiedByAdminId String?
  verifiedByAdmin   User?    @relation(fields: [verifiedByAdminId], references: [id])

  verifiedAt        DateTime?
  createdAt         DateTime @default(now())

  issue             Issue    @relation(fields: [issueId], references: [id])
}

